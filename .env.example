# ==========================================
# 통합 환경 변수 설정 파일 (.env)
# ==========================================

# 1. 공통 사용 변수 (백엔드 런타임 & 프론트엔드 빌드)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# 2. 백엔드(Go) 전용
PORT=8080
JWT_SECRET=your_super_secret_jwt_key
ADMIN_GOOGLE_EMAIL=your.email@gmail.com
DOCKER_HUB_USERNAME=woong2e # (필요시 Docker Compose 이미지 경로용)

# 3. 프론트엔드(React) 전용
# 로컬 개발 시: http://localhost:8080/api  |  운영 서버 배포 시: https://woong2e-prod.com/api
VITE_API_BASE_URL=/api
